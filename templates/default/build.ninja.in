# ---- パラメータ ----
deck  = @DECK@
bin   = @BIN@
share = @SHARE@

# 1 caption(=1 フレーム/SRT エントリ)の表示時間(ミリ秒)。
# caption2srt の --ms と動画の framerate(=1000/capms fps) を両方ここで決める。
capms     = 800

# 各文の前後に空ける余白(ミリ秒)。
# head_ms: 音声の頭出し delay = head_ms + (A-1)*capms
# tail_ms: 文末の無音余白
head_ms   = 50
tail_ms   = 10

# 速すぎ防止。再生倍率がこの値を超える文はフレームを追加してレートを下げる。
threshold = 1.3

# 字幕 1 行の最大文字数。超えたら文節単位で折り返して次の caption にする。
max_chars = 10

# Azure TTS の SSML break(ミリ秒)。break_ms=文節間、end_ms=文末。
# end_ms は 0 推奨: 末尾の間は tail_ms(mux 側)で持ち、wav 自体に無音を焼かない。
break_ms  = 120
end_ms    = 0

include key.ninja

include @RULES@

default video pdf
