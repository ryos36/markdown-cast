# ---- パラメータ ----
deck  = @DECK@
bin   = @BIN@
share = @SHARE@

capms     = 800
head_ms   = 50
tail_ms   = 10
threshold = 1.3
max_chars = 10
break_ms  = 120
end_ms    = 0

# Azure TTS の設定（ninja wav を使うときだけ必要）
# 詳しくは azure.md を参照。キーはコミットしないこと。
# key    = YOUR_AZURE_KEY
# region = japaneast
# voice  = ja-JP-NanamiNeural

include @RULES@

default with-caption.mp4
