# ---- パラメータ ----
deck  = rawls-san
bin   = ../../bin
share = .

capms     = 800
head_ms   = 50
tail_ms   = 10
threshold = 1.3
max_chars = 20
break_ms  = 120
end_ms    = 0

# Azure TTS の設定（ninja wav を使うときだけ必要）
# key    = $AZURE_KEY
# region = japaneast
# voice  = ja-JP-NanamiNeural

include ../../share/rules.ninja

default video-audio pdf
