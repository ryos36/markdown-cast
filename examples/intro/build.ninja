# ---- パラメータ ----
deck       = intro
bin        = ../../bin
mecab_dict = mecab-private.dict.ss
pron_dict  = pronunciation.dict.ss

capms     = 800
head_ms   = 50
tail_ms   = 10
threshold = 1.3
max_chars = 20

# 字幕・音声から句読点（。、）を落とす。残したいときはこの行を空にする（strip_opt =）。
strip_opt = --strip-punctuation

break_ms  = 120
end_ms    = 0

include key.ninja

include ../../share/rules.ninja

default video video-audio pdf
