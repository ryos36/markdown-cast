# RUN: mkdir -p %T/orig
# RUN: python3 -c "import wave; f=wave.open('%T/orig/output.001.wav','w'); f.setnchannels(1); f.setsampwidth(2); f.setframerate(24000); f.writeframes(b'\x00\x00'*14400); f.close()"
# RUN: env VIDEO=fake.mp4 OUT=%T/out.mp4 WAVLISTSS=%S/fixtures/single-entry.wavlist.ss ORIG_WAV_DIR=%T/orig FINAL_WAV_DIR=%T/final HEAD_MS=50 FRAME_MS=800 DRY=1 sh %S/../../bin/final_audio_mux.sh 2>&1 | grep -qF "adelay=50|50"
