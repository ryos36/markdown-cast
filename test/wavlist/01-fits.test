# RUN: mkdir -p %T/fits
# RUN: python3 -c "import wave; f=wave.open('%T/fits/output.001.wav','w'); f.setnchannels(1); f.setsampwidth(2); f.setframerate(24000); f.writeframes(b'\x00\x00'*14400); f.close()"
# RUN: ros %S/../../bin/tts2wavlist.ros -i %S/fixtures/single-sentence.tts.ss --capms 800 --head-ms 50 --tail-ms 10 --threshold 1.3 %T/fits/output.{%03i}.wav NEW/output.{%03i}.wav > %t.raw
# RUN: sed 's|%T/fits/|ORIG/|g' %t.raw > %t
# RUN: diff %S/expected/01-fits.ss %t
